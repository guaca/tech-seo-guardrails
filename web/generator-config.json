            "enabled": true,
            "severity": "warning",
            "value": ""
          },
          "maxCanonicalTags": {
            "enabled": true,
            "severity": "warning",
            "value": 1
          },
          "maxRobotsTags": {
            "enabled": true,
            "severity": "warning",
            "value": 1
          },
          "selfReferencingCanonical": {
            "enabled": true,
            "severity": "warning",
            "value": true
          },
          "hreflang": {
            "enabled": true,
            "severity": "warning",
            "value": null
          },
          "hasCharset": {
            "enabled": true,
            "severity": "warning",
            "value": true
          },
          "hasViewport": {
            "enabled": true,
            "severity": "warning",
            "value": true
