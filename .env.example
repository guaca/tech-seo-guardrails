# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# ─── Where tests send requests ────────────────────────────────────────────────
# Set this to your running dev server, a preview deployment, or a staging URL.
# If not set, tests fall back to PROD_BASE_URL, then to http://localhost:3000.
#
# Examples:
#   Local dev server:        TEST_BASE_URL=http://localhost:3000
#   Remote preview URL:      TEST_BASE_URL=https://preview-branch-abc.vercel.app
#   Staging environment:     TEST_BASE_URL=https://staging.your-site.com
TEST_BASE_URL=http://localhost:3000

# ─── Canonical production URL ─────────────────────────────────────────────────
# The production URL of your site. Used for:
#   - Canonical URL matching (checking <link rel="canonical"> values)
#   - Classifying internal vs external links
#   - Sitemap and robots.txt checks when TEST_BASE_URL is not set
#
# This should never change between runs — it's always your production domain.
# Overrides the baseUrl field in seo-checks.json if both are set.
PROD_BASE_URL=https://your-site.com

# ─── Canonical URL mode ───────────────────────────────────────────────────────
# Controls how canonical tag checks compare expected vs actual canonical URLs.
#
#   production (default) — canonicals always point to the prod domain, even when
#                          tests run on localhost or a preview URL.
#                          selfReferencingCanonical compares against PROD_BASE_URL + path.
#                          Use this for most sites.
#
#   dynamic              — canonicals reflect the current host. Use this when your
#                          framework rewrites canonicals to match the environment it's on
#                          (e.g. Next.js with NEXT_PUBLIC_SITE_URL set per environment).
#                          selfReferencingCanonical compares against page.url().
#
SEO_CANONICAL_MODE=production

# ─── Page sampling ────────────────────────────────────────────────────────────
# Maximum pages tested per template in the integration suite.
# Overrides sampleConfig.maxPagesPerTemplate in seo-checks.json.
# Leave unset to use the JSON value, or run all pages if neither is set.
# Ignored when SEO_LANE=scheduled (scheduled always runs all pages).
SEO_SAMPLE_LIMIT=

# ─── Lane filtering ───────────────────────────────────────────────────────────
# Controls which lane-gated checks run.
# Options: pr | merge | scheduled | (leave empty to run all checks)
# Note: Leave this empty for local development to ensure all checks run.
SEO_LANE=
